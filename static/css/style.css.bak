/* ===== Modern Event Ticketing System Styles ===== */

:root {
    /* Primary Color Palette - Vibrant and Modern */
    --primary-gradient-start: #6366f1;
    --primary-gradient-end: #8b5cf6;
    --primary-color: #7c3aed;
    --primary-dark: #5b21b6;
    --primary-light: #a78bfa;

    /* Secondary Colors */
    --secondary-color: #0f172a;
    --secondary-light: #1e293b;
    --accent-color: #06b6d4;

    /* Semantic Colors */
    --success-color: #10b981;
    --success-bg: #d1fae5;
    --success-gradient: linear-gradient(135deg, #10b981 0%, #059669 100%);
    --warning-color: #f59e0b;
    --warning-bg: #fef3c7;
    --warning-gradient: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
    --danger-color: #ef4444;
    --danger-bg: #fee2e2;
    --danger-gradient: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
    --info-color: #3b82f6;
    --info-bg: #dbeafe;
    --info-gradient: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);

    /* Text Colors - High Contrast */
    --text-primary: #0f172a;
    --text-secondary: #475569;
    --text-muted: #64748b;
    --text-light: #94a3b8;
    --text-on-dark: #ffffff;
    --text-on-primary: #ffffff;

    /* Background Colors */
    --bg-primary: #ffffff;
    --bg-secondary: #f8fafc;
    --bg-tertiary: #f1f5f9;
    --bg-gradient: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    --bg-gradient-alt: linear-gradient(135deg, #667eea 0%, #764ba2 100%);

    /* Dashboard Specific Colors */
    --dashboard-bg: #f8fafc;
    --dashboard-card-bg: #ffffff;
    --dashboard-text: #0f172a;
    --dashboard-accent: #6366f1;

    /* Shadows */
    --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
    --shadow-md: 0 4px 6px rgba(0, 0, 0, 0.08);
    --shadow-lg: 0 10px 15px rgba(0, 0, 0, 0.1);
    --shadow-xl: 0 20px 25px rgba(0, 0, 0, 0.15);
    --shadow-glow: 0 0 20px rgba(99, 102, 241, 0.3);

    /* Border Radius */
    --radius-sm: 0.375rem;
    --radius-md: 0.5rem;
    --radius-lg: 0.75rem;
    --radius-xl: 1rem;
    --radius-2xl: 1.5rem;
    --radius-full: 9999px;

    /* Transitions */
    --transition-fast: 150ms cubic-bezier(0.4, 0, 0.2, 1);
    --transition-base: 200ms cubic-bezier(0.4, 0, 0.2, 1);
    --transition-slow: 300ms cubic-bezier(0.4, 0, 0.2, 1);
}

/* ===== Reset & Base ===== */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth;
}

body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    background-color: var(--dashboard-bg);
    color: var(--text-primary);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
}

.container {
    flex: 1;
    max-width: 1400px;
}

/* ===== Navbar ===== */
.navbar {
    box-shadow: var(--shadow-md);
    transition: all var(--transition-base);
    background: linear-gradient(135deg, #1e1b4b 0%, #2d3748 100%) !important;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.navbar-brand {
    font-size: 1.5rem;
    font-weight: 700;
    background: linear-gradient(135deg, var(--primary-gradient-start), var(--primary-gradient-end));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    transition: all var(--transition-base);
}

.navbar-brand:hover {
    transform: scale(1.05);
    filter: brightness(1.1);
}

.navbar-dark .nav-link {
    color: rgba(255, 255, 255, 0.85) !important;
    font-weight: 500;
    padding: 0.5rem 1rem !important;
    border-radius: var(--radius-sm);
    transition: all var(--transition-base);
    position: relative;
}

.navbar-dark .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--primary-gradient-start), var(--primary-gradient-end));
    transition: all var(--transition-base);
    transform: translateX(-50%);
    border-radius: var(--radius-full);
}

.navbar-dark .nav-link:hover {
    color: #ffffff !important;
    background: rgba(255, 255, 255, 0.1);
}

.navbar-dark .nav-link:hover::after {
    width: 80%;
}

.navbar-dark .nav-link.active {
    color: #ffffff !important;
    background: rgba(255, 255, 255, 0.15);
}

.navbar-dark .nav-link.active::after {
    width: 80%;
}

.navbar-toggler {
    border: 2px solid rgba(255, 255, 255, 0.2);
    padding: 0.5rem;
    border-radius: var(--radius-md);
    transition: all var(--transition-base);
}

.navbar-toggler:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.3);
}

.navbar-toggler-icon {
    width: 1.5rem;
    height: 1.5rem;
}

/* ===== Cards ===== */
.card {
    border: 1px solid rgba(99, 102, 241, 0.1);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
    transition: all var(--transition-base);
    background: var(--dashboard-card-bg);
    overflow: hidden;
}

.card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
    border-color: rgba(99, 102, 241, 0.2);
}

.card-header {
    border: none;
    padding: 1.25rem 1.5rem;
    font-weight: 600;
    background: var(--bg-gradient);
    color: var(--text-on-primary);
    position: relative;
}

.card-header::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: rgba(255, 255, 255, 0.2);
}

.card-header h5, .card-header h4, .card-header h3, .card-header h6 {
    color: var(--text-on-primary);
    margin: 0;
}

.card-body {
    padding: 1.5rem;
    color: var(--dashboard-text);
}

.card-footer {
    border: none;
    padding: 1rem 1.5rem;
    background: var(--dashboard-bg);
    border-top: 1px solid rgba(99, 102, 241, 0.1);
}

.card-title {
    font-weight: 700;
    color: var(--dashboard-text);
    margin-bottom: 0.5rem;
}

/* ===== Buttons ===== */
.btn {
    border-radius: var(--radius-lg);
    font-weight: 600;
    padding: 0.625rem 1.25rem;
    transition: all var(--transition-base);
    border: none;
    position: relative;
    overflow: hidden;
}

.btn::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    border-radius: var(--radius-full);
    background: rgba(255, 255, 255, 0.3);
    transform: translate(-50%, -50%);
    transition: width var(--transition-slow), height var(--transition-slow);
}

.btn:active::before {
    width: 300px;
    height: 300px;
}

.btn:active {
    transform: scale(0.98);
}

.btn-lg {
    padding: 0.75rem 2rem;
    font-size: 1.1rem;
}

.btn-sm {
    padding: 0.375rem 0.875rem;
    font-size: 0.875rem;
}

.btn-primary {
    background: var(--bg-gradient);
    border-color: transparent;
    color: var(--text-on-primary);
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.35);
}

.btn-primary:hover {
    background: var(--primary-gradient-alt);
    box-shadow: 0 6px 20px rgba(99, 102, 241, 0.45);
    transform: translateY(-2px);
}

.btn-primary:active {
    background: var(--primary-gradient-alt);
    transform: translateY(0) scale(0.98);
}

.btn-success {
    background: var(--success-gradient);
    border-color: transparent;
    color: var(--text-on-primary);
}

.btn-success:hover {
    filter: brightness(1.1);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(16, 185, 129, 0.35);
}

.btn-warning {
    background: var(--warning-gradient);
    border-color: transparent;
    color: #0f172a;
}

.btn-warning:hover {
    filter: brightness(1.1);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(245, 158, 11, 0.35);
}

.btn-danger {
    background: var(--danger-gradient);
    border-color: transparent;
    color: var(--text-on-primary);
}

.btn-danger:hover {
    filter: brightness(1.1);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(239, 68, 68, 0.35);
}

.btn-info {
    background: var(--info-gradient);
    border-color: transparent;
    color: var(--text-on-primary);
}

.btn-info:hover {
    filter: brightness(1.1);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.35);
}

.btn-outline-primary {
    background: transparent;
    border: 2px solid var(--primary-color);
    color: var(--primary-color);
}

.btn-outline-primary:hover {
    background: var(--primary-color);
    color: var(--text-on-primary);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
}

.btn-outline-secondary {
    background: transparent;
    border: 2px solid var(--text-muted);
    color: var(--text-muted);
}

.btn-outline-secondary:hover {
    background: var(--text-muted);
    color: var(--text-on-primary);
    transform: translateY(-2px);
}

.btn-outline-success {
    background: transparent;
    border: 2px solid var(--success-color);
    color: var(--success-color);
}

.btn-outline-success:hover {
    background: var(--success-color);
    color: var(--text-on-primary);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
}

.btn-group {
    display: flex;
    gap: 0.5rem;
}

.btn-group .btn {
    border-radius: var(--radius-md);
}

/* ===== Forms ===== */
.form-control,
.form-select {
    border-radius: var(--radius-lg);
    border: 2px solid #e2e8f0;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    transition: all var(--transition-base);
    background: var(--dashboard-card-bg);
    color: var(--dashboard-text);
}

.form-control:focus,
.form-select:focus {
    border-color: var(--primary-color);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
    outline: none;
}

.form-control::placeholder {
    color: var(--text-muted);
}

.form-label {
    font-weight: 600;
    color: var(--dashboard-text);
    margin-bottom: 0.5rem;
    font-size: 0.95rem;
}

.input-group {
    border-radius: var(--radius-lg);
    overflow: hidden;
}

.input-group-text {
    background: var(--dashboard-bg);
    border: 2px solid #e2e8f0;
    color: var(--text-secondary);
}

.input-group .form-control {
    border-left: none;
}

.input-group .form-control:focus {
    border-color: var(--primary-color);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
}

.form-check-input {
    width: 1.25rem;
    height: 1.25rem;
    cursor: pointer;
    border: 2px solid #e2e8f0;
    border-radius: var(--radius-sm);
    transition: all var(--transition-base);
}

.form-check-input:checked {
    background-color: var(--primary-color);
    border-color: var(--primary-color);
}

.form-check-input:focus {
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.25);
}

/* ===== Tables ===== */
.table {
    background: var(--dashboard-card-bg);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    border: 1px solid rgba(99, 102, 241, 0.1);
}

.table thead {
    background: var(--bg-gradient);
    color: var(--text-on-primary);
}

.table thead th {
    border: none;
    padding: 1rem 0.875rem;
    font-weight: 600;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.table tbody tr {
    border-bottom: 1px solid rgba(99, 102, 241, 0.1);
    transition: all var(--transition-base);
}

.table tbody tr:hover {
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.05) 0%, rgba(139, 92, 246, 0.05) 100%);
    transform: scale(1.005);
}

.table tbody tr:last-child {
    border-bottom: none;
}

.table td {
    vertical-align: middle;
    padding: 1rem 0.875rem;
    color: var(--dashboard-text);
}

/* ===== Badges ===== */
.badge {
    padding: 0.5rem 0.875rem;
    font-weight: 600;
    font-size: 0.75rem;
    border-radius: var(--radius-full);
    letter-spacing: 0.025em;
}

.badge.bg-primary {
    background: var(--bg-gradient);
    color: var(--text-on-primary);
}

.badge.bg-success {
    background: var(--success-gradient);
    color: var(--text-on-primary);
}

.badge.bg-warning {
    background: var(--warning-gradient);
    color: #0f172a;
}

.badge.bg-danger {
    background: var(--danger-gradient);
    color: var(--text-on-primary);
}

.badge.bg-info {
    background: var(--info-gradient);
    color: var(--text-on-primary);
}

.badge.bg-secondary {
    background: #64748b;
    color: var(--text-on-primary);
}

/* ===== Statistics Cards ===== */
.stat-card {
    text-align: center;
    padding: 1.75rem 1.25rem;
    border-radius: var(--radius-xl);
    color: var(--text-on-primary);
    font-weight: 600;
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition: all var(--transition-base);
}

.stat-card::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, transparent 60%);
    transform: rotate(45deg);
}

.stat-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
}

.stat-card h2 {
    font-size: 2.5rem;
    margin: 0.5rem 0;
    font-weight: 800;
}

.stat-card h5 {
    margin: 0;
    font-weight: 600;
    opacity: 0.95;
}

.stat-card i {
    font-size: 1.75rem;
    margin-bottom: 0.5rem;
    opacity: 0.9;
}

.stat-card.bg-primary {
    background: var(--bg-gradient);
}

.stat-card.bg-success {
    background: var(--success-gradient);
}

.stat-card.bg-warning {
    background: var(--warning-gradient);
    color: #0f172a;
}

.stat-card.bg-info {
    background: var(--info-gradient);
}

.stat-card.bg-secondary {
    background: #64748b;
}

/* ===== Alerts ===== */
.alert {
    border: 1px solid transparent;
    border-radius: var(--radius-lg);
    padding: 1rem 1.25rem;
    animation: slideDown var(--transition-slow) ease-out;
}

@keyframes slideDown {
    from {
        opacity: 0;
        transform: translateY(-20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.alert-success {
    background: var(--success-bg);
    color: #065f46;
    border-left: 4px solid var(--success-color);
}

.alert-danger {
    background: var(--danger-bg);
    color: #991b1b;
    border-left: 4px solid var(--danger-color);
}

.alert-warning {
    background: var(--warning-bg);
    color: #92400e;
    border-left: 4px solid var(--warning-color);
}

.alert-info {
    background: var(--info-bg);
    color: #1e40af;
    border-left: 4px solid var(--info-color);
}

/* ===== Footer ===== */
footer {
    margin-top: auto;
    background: linear-gradient(135deg, #1e1b4b 0%, #2d3748 100%) !important;
    color: white;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: 1.5rem 0;
}

footer p {
    margin: 0;
    opacity: 0.9;
}

/* ===== Utility Classes ===== */
.text-primary { color: var(--primary-color) !important; }
.text-success { color: var(--success-color) !important; }
.text-danger { color: var(--danger-color) !important; }
.text-warning { color: var(--warning-color) !important; }
.text-info { color: var(--info-color) !important; }

.text-muted { color: var(--text-muted) !important; }

.bg-light-primary { background-color: rgba(99, 102, 241, 0.1); }
.bg-light-success { background-color: rgba(16, 185, 129, 0.1); }
.bg-light-danger { background-color: rgba(239, 68, 68, 0.1); }

.bg-gradient {
    background: var(--bg-gradient);
    color: var(--text-on-primary);
}

/* ===== Code Styling ===== */
code {
    background: var(--dashboard-bg);
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius-sm);
    color: var(--primary-color);
    font-family: 'Fira Code', 'Consolas', 'Monaco', monospace;
    font-size: 0.875rem;
    border: 1px solid rgba(99, 102, 241, 0.2);
}

pre {
    background: #0f172a;
    color: #e2e8f0;
    padding: 1.25rem;
    border-radius: var(--radius-lg);
    overflow-x: auto;
    border-left: 4px solid var(--primary-color);
}

/* ===== Loading States ===== */
.loading {
    display: inline-block;
    width: 1.25rem;
    height: 1.25rem;
    border: 3px solid rgba(99, 102, 241, 0.2);
    border-top-color: var(--primary-color);
    border-radius: var(--radius-full);
    animation: spin 0.8s linear infinite;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

.spinner-border {
    width: 2.5rem;
    height: 2.5rem;
}

/* ===== Modal ===== */
.modal-content {
    border: 1px solid rgba(99, 102, 241, 0.2);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-xl);
    overflow: hidden;
    background: var(--dashboard-card-bg);
    color: var(--dashboard-text);
}

.modal-header {
    background: var(--bg-gradient);
    color: var(--text-on-primary);
    border: none;
    padding: 1.25rem 1.5rem;
}

.modal-header .btn-close {
    filter: brightness(0) invert(1);
    opacity: 0.8;
    transition: opacity var(--transition-base);
}

.modal-header .btn-close:hover {
    opacity: 1;
}

.modal-body {
    padding: 1.5rem;
    background: var(--dashboard-card-bg);
}

.modal-footer {
    border: none;
    padding: 1rem 1.5rem;
    background: var(--dashboard-bg);
    border-top: 1px solid rgba(99, 102, 241, 0.1);
}

.modal-footer .btn {
    color: var(--dashboard-text);
}

/* ===== Dropdown ===== */
.dropdown-menu {
    border: 1px solid rgba(99, 102, 241, 0.15);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xl);
    padding: 0.5rem 0;
    background: var(--dashboard-card-bg);
}

.dropdown-item {
    padding: 0.625rem 1rem;
    border-radius: var(--radius-md);
    transition: all var(--transition-base);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 500;
    color: var(--dashboard-text);
}

.dropdown-item:hover {
    background: var(--dashboard-bg);
    color: var(--primary-color);
    transform: translateX(4px);
}

/* ===== Custom Scrollbar ===== */
::-webkit-scrollbar {
    width: 10px;
    height: 10px;
}

::-webkit-scrollbar-track {
    background: var(--dashboard-bg);
    border-radius: var(--radius-full);
}

::-webkit-scrollbar-thumb {
    background: var(--bg-gradient);
    border-radius: var(--radius-full);
    border: 2px solid rgba(99, 102, 241, 0.2);
}

::-webkit-scrollbar-thumb:hover {
    background: var(--primary-color);
}

/* ===== Animations ===== */
@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes pulse {
    0%, 100% {
        opacity: 1;
        transform: scale(1);
    }
    50% {
        opacity: 0.5;
        transform: scale(0.95);
    }
}

@keyframes float {
    0%, 100% {
        transform: translateY(0px);
    }
    50% {
        transform: translateY(-10px);
    }
}

.animate-fade-in {
    animation: fadeIn var(--transition-slow) ease-out;
}

.animate-pulse {
    animation: pulse 2s ease-in-out infinite;
}

.animate-float {
    animation: float 3s ease-in-out infinite;
}

/* ===== Responsive Design ===== */
@media (max-width: 767.98px) {
    .container {
        padding: 0 1rem;
        max-width: 100%;
    }

    body {
        font-size: 0.95rem;
    }

    .navbar-brand {
        font-size: 1.25rem;
    }

    .navbar-toggler {
        padding: 0.25rem 0.5rem;
    }

    .card {
        margin-bottom: 1rem;
    }

    .card-body {
        padding: 1.25rem;
    }

    .btn {
        width: 100%;
        margin-bottom: 0.5rem;
    }

    .btn-group {
        flex-direction: column;
        width: 100%;
    }

    .btn-group .btn {
        border-radius: var(--radius-md) !important;
    }

    .table-responsive {
        font-size: 0.85rem;
    }

    .table thead th,
    .table td {
        padding: 0.75rem 0.5rem;
    }

    .stat-card {
        margin-bottom: 1rem;
    }

    .stat-card h2 {
        font-size: 2rem;
    }

    .dropdown-menu {
        position: fixed !important;
        top: auto !important;
        left: 1rem !important;
        right: 1rem !important;
        width: calc(100% - 2rem) !important;
    }
}

/* Small mobile devices */
@media (max-width: 575.98px) {
    .container {
        padding: 0 0.75rem;
        max-width: 100%;
    }

    h1 { font-size: 1.75rem; }
    h2 { font-size: 1.5rem; }
    h3 { font-size: 1.25rem; }

    .card-header {
        padding: 1rem 1.25rem;
        font-size: 1rem;
    }

    .card-body {
        padding: 1rem;
    }

    .table-responsive {
        font-size: 0.8rem;
    }

    .table thead th,
    .table td {
        padding: 0.5rem 0.375rem;
    }

    .badge {
        padding: 0.375rem 0.625rem;
        font-size: 0.65rem;
    }

    .btn-sm {
        padding: 0.3125rem 0.625rem;
        font-size: 0.75rem;
    }
}

/* Tablet optimizations */
@media (min-width: 768px) and (max-width: 1024px) {
    .container {
        padding: 0 1.5rem;
    }

    .card-body {
        padding: 1.25rem;
    }
}

/* Large screens */
@media (min-width: 1200px) {
    .container {
        max-width: 1400px;
    }
}

/* Print styles */
@media print {
    .navbar,
    .btn,
    .alert {
        display: none !important;
    }

    body {
        background: white;
    }

    .card {
        box-shadow: none;
        border: 1px solid #e2e8f0;
    }
}

/* ===== Dark Mode Support ===== */
@media (prefers-color-scheme: dark) {
    body {
        background: #0f172a;
        color: #e2e8f0;
    }

    .card,
    .modal-content,
    .dropdown-menu,
    .table {
        background: #1e293b;
        border-color: rgba(99, 102, 241, 0.3);
    }

    .form-control,
    .form-select {
        background: #0f172a;
        border-color: #475569;
        color: #e2e8f0;
    }

    .form-control::placeholder {
        color: #64748b;
    }

    .dropdown-item:hover {
        background: #0f172a;
        color: var(--primary-color);
    }

    .table tbody tr:hover {
        background: rgba(99, 102, 241, 0.1);
    }
}

/* ===== High Contrast Mode ===== */
@media (prefers-contrast: high) {
    :root {
        --shadow-sm: 0 2px 0 rgba(0, 0, 0, 0.2);
        --shadow-md: 0 4px 0 rgba(0, 0, 0, 0.3);
    }

    .btn {
        border: 2px solid currentColor;
    }

    .card {
        border: 2px solid var(--text-secondary);
    }
}

/* ===== Reduced Motion ===== */
@media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
    }
}
